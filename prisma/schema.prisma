generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                   @id @default(cuid())
  name                      String
  email                     String                   @unique
  passwordHash              String
  avatarUrl                 String?
  phone                     String?
  department                String?
  role                      String                   @default("user")
  teamId                    String?
  emailVerifiedAt           DateTime?
  emailVerificationRequired Boolean                  @default(false)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  bookings                  Booking[]
  refreshTokens             RefreshToken[]
  emailVerificationTokens   EmailVerificationToken[]
  communityMemberships      CommunityMembership[]
  communityMessages         CommunityMessage[]
}

model Room {
  id         String    @id @default(cuid())
  name       String
  floor      Int
  capacity   Int
  utilities  Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  desks      Desk[]
  bookings   Booking[]
}

model Desk {
  id         String    @id @default(cuid())
  name       String
  roomId     String
  status     String    @default("available")
  position   Json
  width      Float?
  height     Float?
  type       String?
  rotation   Float?
  utilities  Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookings   Booking[]

  @@index([roomId])
}

model Booking {
  id           String    @id @default(cuid())
  userId       String
  deskId       String
  roomId       String
  dateKey      String
  duration     String
  timeSlot     Json?
  status       String    @default("confirmed")
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  desk         Desk      @relation(fields: [deskId], references: [id], onDelete: Cascade)
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
  @@index([deskId, dateKey])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model CommunitySpace {
  id          String                @id @default(cuid())
  slug        String                @unique
  name        String
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  memberships CommunityMembership[]
  messages    CommunityMessage[]
}

model CommunityMembership {
  id         String         @id @default(cuid())
  spaceId    String
  userId     String
  joinedAt   DateTime       @default(now())
  lastReadAt DateTime?
  space      CommunitySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([userId, joinedAt])
}

model CommunityMessage {
  id        String         @id @default(cuid())
  spaceId   String
  senderId  String
  content   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  space     CommunitySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sender    User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachments CommunityMessageAttachment[]

  @@index([spaceId, createdAt])
  @@index([senderId, createdAt])
}

model CommunityMessageAttachment {
  id        String           @id @default(cuid())
  messageId String
  kind      String
  fileName  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime         @default(now())
  message   CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}
