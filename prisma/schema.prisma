generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  avatarUrl    String?
  phone        String?
  department   String?
  role         String    @default("user")
  teamId       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
  refreshTokens RefreshToken[]
}

model Room {
  id         String    @id @default(cuid())
  name       String
  floor      Int
  capacity   Int
  utilities  Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  desks      Desk[]
  bookings   Booking[]
}

model Desk {
  id         String    @id @default(cuid())
  name       String
  roomId     String
  status     String    @default("available")
  position   Json
  width      Float?
  height     Float?
  type       String?
  rotation   Float?
  utilities  Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookings   Booking[]

  @@index([roomId])
}

model Booking {
  id           String    @id @default(cuid())
  userId       String
  deskId       String
  roomId       String
  dateKey      String
  duration     String
  timeSlot     Json?
  status       String    @default("confirmed")
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  desk         Desk      @relation(fields: [deskId], references: [id], onDelete: Cascade)
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
  @@index([deskId, dateKey])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}
